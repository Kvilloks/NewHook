#include <windows.h>
#include <stdio.h>
#include <tlhelp32.h>
#include "MinHook.h"

// Логфайл
FILE* logfile = nullptr;

// Прототипы оригинальных функций
typedef int (WINAPI* SEND)(SOCKET, const char*, int, int);
typedef int (WINAPI* WSASEND)(SOCKET, LPWSABUF, DWORD, LPDWORD, DWORD, LPVOID, LPWSAOVERLAPPED_COMPLETION_ROUTINE);

SEND orig_send = nullptr;
WSASEND orig_wsasend = nullptr;

// Hook для send
int WINAPI hook_send(SOCKET s, const char* buf, int len, int flags) {
    fprintf(logfile, "[SEND] Buf: %.*s\n", len, buf);
    fflush(logfile);
    // Поиск ключевых слов
    if (strstr(buf, "key") || strstr(buf, "token") || strstr(buf, "license")) {
        fprintf(logfile, "[KEYWORD] Найден возможный ключ: %.*s\n", len, buf);
    }
    return orig_send(s, buf, len, flags);
}

// Hook для WSASend
int WINAPI hook_wsasend(SOCKET s, LPWSABUF lpBuffers, DWORD dwBufferCount, LPDWORD lpNumberOfBytesSent,
                        DWORD dwFlags, LPVOID lpOverlapped, LPWSAOVERLAPPED_COMPLETION_ROUTINE lpCompletionRoutine) {
    for (DWORD i = 0; i < dwBufferCount; ++i) {
        fprintf(logfile, "[WSASend] [%u/%u] Buf: %.*s\n", i + 1, dwBufferCount, lpBuffers[i].len, lpBuffers[i].buf);
        // Ищем ключи
        if (strstr((const char*)lpBuffers[i].buf, "key") || strstr((const char*)lpBuffers[i].buf, "license")) {
            fprintf(logfile, "[KEYWORD] Найден ключ в буфере WSASend!\n");
        }
    }
    fflush(logfile);
    return orig_wsasend(s, lpBuffers, dwBufferCount, lpNumberOfBytesSent, dwFlags, lpOverlapped, lpCompletionRoutine);
}

// Хук загрузки модулей (LoadLibraryA)
typedef HMODULE (WINAPI* LOADLIBRARYA)(LPCSTR);
LOADLIBRARYA orig_loadlibrarya = nullptr;
HMODULE WINAPI hook_loadlibrarya(LPCSTR lpLibFileName) {
    fprintf(logfile, "[LOADMODULE] %s\n", lpLibFileName);
    fflush(logfile);
    return orig_loadlibrarya(lpLibFileName);
}

// Отдельная функция: вывести все модули процесса
void DumpModules() {
    HANDLE hSnapshot = CreateToolhelp32Snapshot(TH32CS_SNAPMODULE, GetCurrentProcessId());
    MODULEENTRY32 me;
    me.dwSize = sizeof(me);
    if (Module32First(hSnapshot, &me)) {
        do {
            fprintf(logfile, "[MODULE] %ws - 0x%p\n", me.szModule, me.modBaseAddr);
        } while (Module32Next(hSnapshot, &me));
    }
    CloseHandle(hSnapshot);
}

// Установка хуков
void SetupHooks() {
    MH_Initialize();
    MH_CreateHookApi(L"Ws2_32.dll", "send", &hook_send, (LPVOID*)&orig_send);
    MH_CreateHookApi(L"Ws2_32.dll", "WSASend", &hook_wsasend, (LPVOID*)&orig_wsasend);
    MH_CreateHookApi(L"kernel32.dll", "LoadLibraryA", &hook_loadlibrarya, (LPVOID*)&orig_loadlibrarya);
    MH_EnableHook(MH_ALL_HOOKS);
}

// Точка входа (DLL main)
BOOL WINAPI DllMain(HINSTANCE hinstDLL, DWORD fdwReason, LPVOID lpReserved) {
    if (fdwReason == DLL_PROCESS_ATTACH) {
        fopen_s(&logfile, "hook_extensive.log", "a+");
        if (logfile) {
            DumpModules(); // Выводим все стартовые модули!
            SetupHooks();
        }
    }
    else if (fdwReason == DLL_PROCESS_DETACH) {
        MH_Uninitialize();
        if (logfile) fclose(logfile);
    }
    return TRUE;
}
